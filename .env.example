# Gemini API Keys — 3 keys are rotated round-robin server-side to avoid rate limits.
# Copy this file to .env and fill in your keys. Never commit .env to git.
GEMINI_API_KEY_1="your-first-gemini-api-key"
GEMINI_API_KEY_2="your-second-gemini-api-key"
GEMINI_API_KEY_3="your-third-gemini-api-key"

# Backend server port (default: 3001)
PORT=3001
